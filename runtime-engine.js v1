window.IBSS_RUNTIME = (function () {
  "use strict";

  const CONFIG = {
    storageKey: "ibss_runtime_state_v3",
    defaultRefreshMs: 4000,
    tickerStepPx: 1,
    tickerFrameMs: 18,
    tickerCopies: 4,
    tickerFallbackText: {
      en: "No live feed available.",
      ar: "لا توجد تغذية حية."
    }
  };

  const STATE = {
    started: false,
    pageId: null,
    lang: "en",

    system: null,
    systemHash: "",

    radarEl: null,
    tickerTrackEl: null,

    systemProvider: null,
    tickerItemsProvider: null,
    afterRender: null,

    refreshTimer: null,
    tickerTimer: null,

    tickerPaused: false,
    tickerContentHash: "",
    tickerBound: false
  };

  function safeNumber(value, fallback = 0) {
    const n = Number(value);
    return Number.isFinite(n) ? n : fallback;
  }

  function safeText(value, fallback = "") {
    return typeof value === "string" && value.trim() ? value.trim() : fallback;
  }

  function asArray(value) {
    return Array.isArray(value) ? value : [];
  }

  function escapeHtml(text) {
    const div = document.createElement("div");
    div.textContent = text ?? "";
    return div.innerHTML;
  }

  function getLocalizedText(value, lang = "en") {
    if (!value) return "-";
    if (typeof value === "string" || typeof value === "number") return String(value);
    return value[lang] || value.en || value.ar || value.name || value.title || value.label || value.text || "-";
  }

  function normalizePriority(value) {
    const p = String(value || "LOW").toUpperCase();
    if (p === "HIGH") return "high";
    if (p === "MEDIUM") return "medium";
    return "low";
  }

  function load() {
    try {
      const raw = localStorage.getItem(CONFIG.storageKey);
      if (!raw) return;

      const parsed = JSON.parse(raw);
      if (!parsed || typeof parsed !== "object") return;

      STATE.pageId = parsed.pageId || null;
      STATE.lang = parsed.lang === "ar" ? "ar" : "en";
    } catch (error) {
      console.error("IBSS_RUNTIME load error:", error);
    }
  }

  function save() {
    try {
      localStorage.setItem(CONFIG.storageKey, JSON.stringify({
        pageId: STATE.pageId,
        lang: STATE.lang
      }));
    } catch (error) {
      console.error("IBSS_RUNTIME save error:", error);
    }
  }

  function buildSystemHash(system) {
    if (!system) return "none";

    const level = safeText(system.level, "LOW");
    const pressure = safeNumber(system.systemPressure || system.ssi, 0);
    const updatedAt = safeText(system.updatedAt, "");
    const topSignalId = safeText(system.topSignal?.id || system.dominantSignal?.id, "none");
    const topClusterId = safeText(system.topCluster?.id, "none");
    const topTheaterId = safeText(system.topTheater?.id, "none");
    const newsCount = safeNumber(system.newsPressure?.count, 0);

    return [
      level,
      pressure,
      updatedAt,
      topSignalId,
      topClusterId,
      topTheaterId,
      newsCount
    ].join("|");
  }

  function getSystem() {
    try {
      if (typeof STATE.systemProvider === "function") {
        return STATE.systemProvider();
      }

      if (window.IBSS_NEWS_UTILS?.autoRefreshIfNeeded) {
        window.IBSS_NEWS_UTILS.autoRefreshIfNeeded();
      }

      if (window.IBSS_ENGINE?.getSystemState) {
        return window.IBSS_ENGINE.getSystemState();
      }

      if (window.IBSS_ENGINE?.getStaticSystemFallback) {
        return window.IBSS_ENGINE.getStaticSystemFallback();
      }
    } catch (error) {
      console.error("IBSS_RUNTIME getSystem error:", error);
    }

    return null;
  }

  function buildDefaultTickerItems(system, lang) {
    const items = [];
    const tickerNews = window.IBSS_NEWS_UTILS?.getTickerNews?.(10) || [];

    tickerNews.forEach(item => {
      items.push({
        level: normalizePriority(item?.severity || item?.priority || "LOW"),
        text: getLocalizedText(item?.title, lang)
      });
    });

    if (!items.length) {
      asArray(system?.feed).slice(0, 10).forEach(line => {
        items.push({
          level: normalizePriority(line?.priority || system?.level || "LOW"),
          text: typeof line === "string" ? line : getLocalizedText(line?.text, lang)
        });
      });
    }

    if (!items.length) {
      items.push({
        level: "low",
        text: lang === "ar" ? CONFIG.tickerFallbackText.ar : CONFIG.tickerFallbackText.en
      });
    }

    return items;
  }

  function getTickerItems(system, lang) {
    try {
      if (typeof STATE.tickerItemsProvider === "function") {
        const custom = STATE.tickerItemsProvider(system, lang);
        if (Array.isArray(custom) && custom.length) {
          return custom.map(item => ({
            level: normalizePriority(item?.level || item?.priority || "LOW"),
            text: safeText(item?.text, "-")
          }));
        }
      }
    } catch (error) {
      console.error("IBSS_RUNTIME tickerItemsProvider error:", error);
    }

    return buildDefaultTickerItems(system, lang);
  }

  function buildTickerContentHash(items, lang) {
    return items.map(item => `${lang}:${item.level}:${item.text}`).join("||");
  }

  function renderTicker(system, force = false) {
    const track = STATE.tickerTrackEl;
    if (!track) return;

    const baseItems = getTickerItems(system, STATE.lang);
    const contentHash = buildTickerContentHash(baseItems, STATE.lang);

    if (!force && contentHash === STATE.tickerContentHash && track.children.length) {
      return;
    }

    STATE.tickerContentHash = contentHash;

    const copies = [];
    for (let i = 0; i < CONFIG.tickerCopies; i += 1) {
      baseItems.forEach(item => copies.push(item));
    }

    track.innerHTML = copies.map(item => `
      <div class="ticker-item">
        <span class="ticker-dot ${escapeHtml(item.level)}"></span>
        <span class="ticker-item-text" dir="${STATE.lang === "ar" ? "rtl" : "ltr"}">${escapeHtml(item.text)}</span>
      </div>
    `).join("");

    track.scrollLeft = 0;
  }

  function bindTickerHover() {
    const track = STATE.tickerTrackEl;
    if (!track || STATE.tickerBound) return;

    STATE.tickerBound = true;

    track.addEventListener("mouseenter", function () {
      STATE.tickerPaused = true;
    });

    track.addEventListener("mouseleave", function () {
      STATE.tickerPaused = false;
    });

    track.addEventListener("touchstart", function () {
      STATE.tickerPaused = true;
    }, { passive: true });

    track.addEventListener("touchend", function () {
      STATE.tickerPaused = false;
    }, { passive: true });

    track.addEventListener("touchcancel", function () {
      STATE.tickerPaused = false;
    }, { passive: true });
  }

  function stopTickerMotion() {
    if (STATE.tickerTimer) {
      clearInterval(STATE.tickerTimer);
      STATE.tickerTimer = null;
    }
  }

  function startTickerMotion() {
    const track = STATE.tickerTrackEl;
    if (!track) return;

    if (STATE.tickerTimer) return;

    bindTickerHover();

    STATE.tickerTimer = setInterval(() => {
      if (!STATE.started || !track || STATE.tickerPaused) return;

      const maxScroll = track.scrollWidth - track.clientWidth;
      if (maxScroll <= 0) return;

      track.scrollLeft += CONFIG.tickerStepPx;

      const resetPoint = Math.max(1, Math.floor(maxScroll / CONFIG.tickerCopies));
      if (track.scrollLeft >= resetPoint) {
        track.scrollLeft = 0;
      }
    }, CONFIG.tickerFrameMs);
  }

  function renderRadar(system, force = false) {
    if (!STATE.radarEl) return;

    try {
      if (window.IBSS_GEO_RADAR?.render) {
        window.IBSS_GEO_RADAR.render(STATE.radarEl, system, {
          lang: STATE.lang,
          size: safeNumber(STATE.radarEl.dataset.radarSize, 300),
          force
        });
      }
    } catch (error) {
      console.error("IBSS_RUNTIME radar render error:", error);
    }
  }

  async function updateAudio(system) {
    try {
      if (window.IBSS_AUDIO?.updateFromSystem) {
        await window.IBSS_AUDIO.updateFromSystem(system);
      }
    } catch (error) {
      console.error("IBSS_RUNTIME audio update error:", error);
    }
  }

  async function tick(options = {}) {
    const system = getSystem();
    if (!system) return null;

    const force = options.force === true;
    const nextHash = buildSystemHash(system);
    const systemChanged = nextHash !== STATE.systemHash;

    STATE.system = system;
    STATE.systemHash = nextHash;

    if (!STATE.tickerTimer) {
      renderTicker(system, true);
      startTickerMotion();
    } else if (force || systemChanged) {
      renderTicker(system, false);
    }

    if (STATE.radarEl && (force || systemChanged)) {
      renderRadar(system, force);
    }

    await updateAudio(system);

    try {
      if (typeof STATE.afterRender === "function") {
        STATE.afterRender(system);
      }
    } catch (error) {
      console.error("IBSS_RUNTIME afterRender error:", error);
    }

    return system;
  }

  function stopRefreshLoop() {
    if (STATE.refreshTimer) {
      clearInterval(STATE.refreshTimer);
      STATE.refreshTimer = null;
    }
  }

  function startRefreshLoop(refreshMs) {
    stopRefreshLoop();

    STATE.refreshTimer = setInterval(() => {
      tick();
    }, refreshMs);
  }

  function start(options = {}) {
    STATE.pageId = options.pageId || STATE.pageId || "ibss-page";
    STATE.lang = options.lang === "ar" ? "ar" : (options.lang || STATE.lang || "en");
    STATE.radarEl = options.radarEl || null;
    STATE.tickerTrackEl = options.tickerTrackEl || null;
    STATE.systemProvider = options.systemProvider || null;
    STATE.tickerItemsProvider = options.tickerItemsProvider || null;
    STATE.afterRender = options.afterRender || null;

    save();

    const refreshMs =
      safeNumber(options.refreshMs, 0) ||
      safeNumber(window.IBSS_ENGINE?.CONFIG?.refreshMs, 0) ||
      CONFIG.defaultRefreshMs;

    STATE.started = true;
    STATE.systemHash = "";
    STATE.tickerContentHash = "";

    stopTickerMotion();
    STATE.tickerBound = false;
    STATE.tickerPaused = false;

    tick({ force: true });
    startRefreshLoop(refreshMs);

    return true;
  }

  function stop() {
    stopRefreshLoop();
    stopTickerMotion();

    STATE.started = false;
    STATE.system = null;
    STATE.systemHash = "";
    STATE.tickerPaused = false;
  }

  function restart(options = {}) {
    stop();
    return start(options);
  }

  function setLanguage(lang) {
    STATE.lang = lang === "ar" ? "ar" : "en";
    save();

    if (STATE.started && STATE.system) {
      STATE.tickerContentHash = "";
      renderTicker(STATE.system, true);
      renderRadar(STATE.system, true);

      try {
        if (typeof STATE.afterRender === "function") {
          STATE.afterRender(STATE.system);
        }
      } catch (error) {
        console.error("IBSS_RUNTIME setLanguage afterRender error:", error);
      }
    }
  }

  function getState() {
    return {
      started: STATE.started,
      pageId: STATE.pageId,
      lang: STATE.lang,
      hasRadar: !!STATE.radarEl,
      hasTicker: !!STATE.tickerTrackEl,
      tickerPaused: STATE.tickerPaused,
      systemHash: STATE.systemHash
    };
  }

  load();

  return {
    CONFIG,
    start,
    stop,
    restart,
    tick,
    setLanguage,
    getState
  };
})();
